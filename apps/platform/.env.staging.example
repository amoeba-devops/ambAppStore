# ============================================================
# ambAppStore Platform — Staging Environment
# ============================================================
# 이 파일은 docker-compose.platform.yml의 env_file로 사용됩니다.
# 서버에 배포 시 apps/platform/.env 에 복사합니다.
# ============================================================

# -- Backend --
NODE_ENV=staging
PORT=3100

# Database
DB_HOST=mysql-apps
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=changeme
DB_DATABASE=db_app_platform

# JWT — AMA에서 발급한 JWT의 서명 검증 키
JWT_SECRET=your-ama-jwt-secret-key

# -- Frontend (Vite build-time) --
VITE_API_BASE_URL=/api
VITE_AMA_LOGIN_URL=https://ama.amoeba.site/login

# -- MySQL --
MYSQL_ROOT_PASSWORD=changeme
