{
  "name": "amb-app-store",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*/frontend",
    "apps/*/backend",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "clean": "turbo run clean",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\""
  },
  "devDependencies": {
    "turbo": "^2.4.0",
    "prettier": "^3.5.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
